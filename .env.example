# Базовый URL API инстанса GREEN-API
# Пример: https://7105.api.green-api.com
GREENAPI_API_URL=

# Базовый URL media инстанса GREEN-API
# Пример: https://7105.media.green-api.com
GREENAPI_MEDIA_URL=

# Формат: idInstance:apiTokenInstance
# Пример: 7105XXXXXXXX:abcdef1234567890...
GREENAPI_INSTANCE_TOKEN=

# Куда писать sqlite архив
WA_ARCHIVE_DB_PATH=./wa_archive.db

# Локальный state ingest
GREENAPI_STATE_PATH=./.greenapi_ingest_state.json

# Таймаут receiveNotification (5..60)
GREENAPI_RECEIVE_TIMEOUT=5

# Пауза между циклами run (сек)
GREENAPI_POLL_SLEEP_SEC=0.5

# Локальная папка для временных media (image/audio)
GREENAPI_MEDIA_STORE_DIR=./data/media

# Хранить media-файлы после обработки (1/0). Default=0 -> text-first + cleanup
GREENAPI_KEEP_MEDIA_FILES=0

# Описывать изображения (1/0)
GREENAPI_DESCRIBE_IMAGES=1

# Включить транскрипцию voice/audio (1/0)
GREENAPI_TRANSCRIBE_AUDIO=1

# Backend описания изображений:
# - auto: сначала OpenClaw gateway, потом OpenAI
# - openclaw: только OpenClaw gateway
# - openai: только OpenAI
# Если describe не удался: text получает только [image description failed],
# а в raw_json.waArchiveIngestDiag.imageDescription ставится pending_reprocess=true.
GREENAPI_IMAGE_DESCRIBE_BACKEND=auto

# OpenAI model для описания изображений (используется при backend=openai или auto)
GREENAPI_DESCRIBE_MODEL=gpt-4o-mini

# OpenClaw gateway URL для image description backend=openclaw/auto
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789

# Опционально: auth для OpenClaw gateway (используется Bearer)
# В зависимости от gateway.auth.mode обычно нужен ИЛИ password, ИЛИ token
OPENCLAW_GATEWAY_PASSWORD=
OPENCLAW_GATEWAY_TOKEN=

# OpenAI model для транскриба (если OPENAI_API_KEY доступен)
GREENAPI_TRANSCRIBE_MODEL=whisper-1

# Опциональный язык транскриба (ru/en/...), пусто = auto
GREENAPI_TRANSCRIBE_LANGUAGE=

# HTTP timeout для вызовов GREENAPI
GREENAPI_HTTP_TIMEOUT_SEC=45
