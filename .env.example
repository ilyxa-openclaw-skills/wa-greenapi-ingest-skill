# Базовый URL API инстанса GREEN-API
# Пример: https://7105.api.green-api.com
GREENAPI_API_URL=

# Базовый URL media инстанса GREEN-API
# Пример: https://7105.media.green-api.com
GREENAPI_MEDIA_URL=

# Формат: idInstance:apiTokenInstance
# Пример: 7105XXXXXXXX:abcdef1234567890...
GREENAPI_INSTANCE_TOKEN=

# Куда писать sqlite архив
WA_ARCHIVE_DB_PATH=./wa_archive.db

# Локальный state ingest
GREENAPI_STATE_PATH=./.greenapi_ingest_state.json

# Таймаут receiveNotification (5..60)
GREENAPI_RECEIVE_TIMEOUT=5

# Пауза между циклами run (сек)
GREENAPI_POLL_SLEEP_SEC=0.5

# Локальная папка для временных media
GREENAPI_MEDIA_STORE_DIR=./data/media

# Хранить media-файлы после обработки (1/0). Default=0 -> text-first + cleanup
GREENAPI_KEEP_MEDIA_FILES=0

# Описывать изображения (1/0)
GREENAPI_DESCRIBE_IMAGES=1

# Включить транскрипцию voice/audio (1/0)
GREENAPI_TRANSCRIBE_AUDIO=1

# Единый backend анализа image/doc:
# - auto: приоритет OpenClaw gateway, для image fallback в OpenAI
# - openclaw: только OpenClaw gateway
# - openai: только OpenAI (практически только для image)
# В OpenClaw image-маршрут для WhatsApp: path-first, image_url как fallback.
GREENAPI_CONTENT_ANALYZE_BACKEND=auto

# Backward compatibility (если GREENAPI_CONTENT_ANALYZE_BACKEND не задан)
GREENAPI_IMAGE_DESCRIBE_BACKEND=auto

# OpenAI model для vision/fallback backend=openai
GREENAPI_DESCRIBE_MODEL=gpt-4o-mini

# OpenClaw gateway URL для image/doc анализа
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789

# Таймаут OpenClaw анализа (сек)
OPENCLAW_CONTENT_ANALYZE_TIMEOUT_SEC=120

# Опционально: auth для OpenClaw gateway (используется Bearer)
# В зависимости от gateway.auth.mode обычно нужен ИЛИ password, ИЛИ token
OPENCLAW_GATEWAY_PASSWORD=
OPENCLAW_GATEWAY_TOKEN=

# PDF политика:
# - pages <= GREENAPI_PDF_MAX_PAGES: обрабатываем целиком
# - pages > GREENAPI_PDF_MAX_PAGES: skip(reason=too_many_pages) + pending_reprocess/manual=true
GREENAPI_PDF_MAX_PAGES=20

# Safeguard лимиты для text/code extraction (default permissive)
GREENAPI_TEXT_ANALYZE_MAX_BYTES=8388608
GREENAPI_TEXT_ANALYZE_MAX_CHARS=2000000

# OpenAI model для транскриба (рекомендовано для RU: gpt-4o-mini-transcribe)
# Fallback цепочка в коде: <GREENAPI_TRANSCRIBE_MODEL> -> whisper-1 -> local whisper
GREENAPI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# Опциональный язык транскриба (ru/en/...), пусто = auto
GREENAPI_TRANSCRIBE_LANGUAGE=

# HTTP timeout для вызовов GREENAPI
GREENAPI_HTTP_TIMEOUT_SEC=45
